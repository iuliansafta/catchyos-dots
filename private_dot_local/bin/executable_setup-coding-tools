#!/usr/bin/env bash
set -Eeuo pipefail

# CachyOS / Arch development bootstrap:
# Rust, Go, Python, direnv, Ansible, Terraform, Docker, lazygit, lazydocker,
# Claude Code, Pi, OpenCode, and useful build basics.
#
# Usage:
#   setup-coding-tools
#   setup-coding-tools --no-upgrade        # install without pacman -Syu first
#   setup-coding-tools --ai-only           # only install/update Claude Code, Pi, OpenCode
#   setup-coding-tools --skip-ai           # skip AI coding tools
#   update-ai-coding-tools --no-upgrade    # convenience wrapper created by this script

NO_UPGRADE=0
AI_ONLY=0
SKIP_AI=0
for arg in "$@"; do
  case "$arg" in
    --no-upgrade) NO_UPGRADE=1 ;;
    --ai-only) AI_ONLY=1 ;;
    --skip-ai) SKIP_AI=1 ;;
    -h|--help)
      sed -n '1,18p' "$0"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      exit 2
      ;;
  esac
done

if (( AI_ONLY && SKIP_AI )); then
  echo "Use either --ai-only or --skip-ai, not both." >&2
  exit 2
fi

if ! command -v pacman >/dev/null 2>&1; then
  echo "This script expects an Arch/CachyOS system with pacman." >&2
  exit 1
fi

log() { printf '\n\033[1;34m==>\033[0m %s\n' "$*"; }

install_packages() {
  local packages=("$@")
  if (( ${#packages[@]} == 0 )); then
    return 0
  fi

  log "Installing system packages"
  if (( NO_UPGRADE )); then
    sudo pacman -S --needed "${packages[@]}"
  else
    # Arch/CachyOS best practice: avoid partial upgrades.
    sudo pacman -Syu --needed "${packages[@]}"
  fi
}

base_packages=(
  base-devel
  git
  curl
  ca-certificates
  pkgconf
  openssl
  nodejs
  npm
  rustup
  go
  python
  python-pip
  python-pipx
  python-virtualenv
  direnv
  ansible
  terraform
  docker
  docker-compose
  lazygit
  lazydocker
)

ai_system_packages=(
  ca-certificates
  curl
  git
  nodejs
  npm
)

if (( AI_ONLY )); then
  install_packages "${ai_system_packages[@]}"
else
  install_packages "${base_packages[@]}"
fi

setup_npm_user_prefix() {
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm is required for Claude Code, Pi, and OpenCode." >&2
    return 1
  fi

  export NPM_PREFIX="$HOME/.local/share/npm-global"
  mkdir -p "$NPM_PREFIX/bin"
  npm config set prefix "$NPM_PREFIX" >/dev/null
  export PATH="$NPM_PREFIX/bin:$PATH"
}

install_ai_tools() {
  if (( SKIP_AI )); then
    return 0
  fi

  setup_npm_user_prefix

  log "Installing/updating AI coding tools from npm"
  # Re-running this script updates these packages to latest.
  npm install -g @anthropic-ai/claude-code@latest
  npm install -g opencode-ai@latest
  npm install -g --ignore-scripts @earendil-works/pi-coding-agent@latest

  cat > "$HOME/.local/bin/update-ai-coding-tools" <<'SH'
#!/usr/bin/env bash
set -Eeuo pipefail
exec "$HOME/.local/bin/setup-coding-tools" --ai-only "$@"
SH
  chmod +x "$HOME/.local/bin/update-ai-coding-tools"
}

setup_docker() {
  if (( AI_ONLY )); then
    return 0
  fi

  if ! command -v docker >/dev/null 2>&1; then
    return 0
  fi

  log "Enabling Docker"
  sudo systemctl enable --now docker.service

  if ! id -nG "$USER" | tr ' ' '\n' | grep -qx docker; then
    sudo usermod -aG docker "$USER"
    DOCKER_GROUP_ADDED=1
  else
    DOCKER_GROUP_ADDED=0
  fi
}

if ! (( AI_ONLY )); then
  log "Preparing Rust stable toolchain"
  if command -v rustup >/dev/null 2>&1; then
    rustup default stable
    rustup component add rustfmt clippy rust-src
  fi

  log "Preparing Python user tooling"
  if command -v pipx >/dev/null 2>&1; then
    python -m pipx ensurepath || true
  fi
fi

setup_docker
install_ai_tools

log "Writing shell integration"
mkdir -p "$HOME/.config/fish/conf.d"
cat > "$HOME/.config/fish/conf.d/dev-env.fish" <<'FISH'
# Generated by setup-coding-tools.
# Rust, Go, Python user tools, npm global tools, and direnv integration.

if test -d "$HOME/.local/share/npm-global/bin"
    fish_add_path "$HOME/.local/share/npm-global/bin"
end

if test -d "$HOME/.cargo/bin"
    fish_add_path "$HOME/.cargo/bin"
end

if test -d "$HOME/go/bin"
    fish_add_path "$HOME/go/bin"
end

if test -d "$HOME/.local/bin"
    fish_add_path "$HOME/.local/bin"
end

if command -q direnv
    direnv hook fish | source
end
FISH

append_block() {
  local file="$1" shell_name="$2" hook_cmd="$3"
  local begin="# >>> setup-coding-tools >>>"
  local end="# <<< setup-coding-tools <<<"

  touch "$file"
  if grep -Fq "$begin" "$file"; then
    local tmp
    tmp="$(mktemp)"
    awk -v begin="$begin" -v end="$end" '
      $0 == begin { skip = 1; next }
      $0 == end { skip = 0; next }
      !skip { print }
    ' "$file" > "$tmp"
    cat "$tmp" > "$file"
    rm -f "$tmp"
  fi

  cat >> "$file" <<EOF

$begin
# Rust, Go, Python user tools, npm global tools, and direnv integration.
export PATH="\$HOME/.local/share/npm-global/bin:\$HOME/.cargo/bin:\$HOME/go/bin:\$HOME/.local/bin:\$PATH"
if command -v direnv >/dev/null 2>&1; then
  $hook_cmd
fi
$end
EOF
}

append_block "$HOME/.bashrc" bash 'eval "$(direnv hook bash)"'
append_block "$HOME/.zshrc" zsh 'eval "$(direnv hook zsh)"'

log "Installed versions"
export PATH="$HOME/.local/share/npm-global/bin:$HOME/.cargo/bin:$HOME/go/bin:$HOME/.local/bin:$PATH"
version_cmds=(
  node
  npm
  rustc
  cargo
  go
  python
  pipx
  direnv
  ansible
  terraform
  lazygit
  lazydocker
  docker
  claude
  pi
  opencode
)

for cmd in "${version_cmds[@]}"; do
  if command -v "$cmd" >/dev/null 2>&1; then
    case "$cmd" in
      ansible) "$cmd" --version | head -1 ;;
      python) "$cmd" --version ;;
      node) "$cmd" --version ;;
      npm) "$cmd" --version | sed 's/^/npm /' ;;
      docker) "$cmd" --version ; docker compose version 2>/dev/null || true ;;
      *) "$cmd" --version 2>/dev/null | head -1 || echo "$cmd: installed" ;;
    esac
  else
    echo "$cmd: not found"
  fi
done

cat <<'DONE'

Done. Open a new terminal, or reload your shell:
  fish: exec fish
  bash: source ~/.bashrc
  zsh:  source ~/.zshrc

Update AI coding tools frequently with:
  update-ai-coding-tools
  update-ai-coding-tools --no-upgrade

Quick checks:
  rustc --version
  go version
  python --version
  direnv version
  ansible --version
  terraform version
  claude --version
  pi --version
  opencode --version

Example direnv project:
  mkdir my-project && cd my-project
  echo 'layout python' > .envrc
  direnv allow
DONE

if [[ ${DOCKER_GROUP_ADDED:-0} == 1 ]]; then
  cat <<'DOCKER'

Docker was installed and your user was added to the docker group.
Log out and back in before running Docker without sudo, then test with:
  docker run hello-world
DOCKER
fi
